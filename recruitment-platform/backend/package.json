{
  "name": "recruitment-platform-backend",
  "version": "1.0.0",
  "description": "AI Recruitment Platform — Backend API",
  "main": "src/server.js",
  "scripts": {
    "predev": "node prisma/use-sqlite.js && prisma generate --schema=prisma/schema.sqlite.prisma",
    "dev": "node --env-file=.env src/server.js",
    "prestart": "node prisma/use-sqlite.js && prisma generate --schema=prisma/schema.sqlite.prisma",
    "start": "node --env-file=.env src/server.js",
    "lint": "eslint src/ --ext .js",
    "lint:fix": "eslint src/ --ext .js --fix",
    "test": "jest --coverage --forceExit --detectOpenHandles",
    "test:unit": "jest --testPathPattern=tests/unit --coverage",
    "test:integration": "node prisma/use-sqlite.js && prisma db push --schema=prisma/schema.sqlite.prisma && jest --testPathPattern=tests/integration --forceExit --detectOpenHandles",
    "test:watch": "jest --watch",
    "migrate:dev": "node prisma/use-sqlite.js && prisma migrate dev --schema=prisma/schema.sqlite.prisma",
    "migrate:deploy": "node prisma/use-sqlite.js && prisma migrate deploy --schema=prisma/schema.sqlite.prisma",
    "migrate:reset": "node prisma/use-sqlite.js && prisma migrate reset --force --schema=prisma/schema.sqlite.prisma",
    "db:push": "node prisma/use-sqlite.js && prisma db push --schema=prisma/schema.sqlite.prisma",
    "db:seed": "prisma db seed",
    "db:studio": "prisma studio --schema=prisma/schema.sqlite.prisma",
    "docker:build": "docker build -t recruitment-backend ."
  },
  "prisma": {
    "seed": "node prisma/seed.js"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1078.0",
    "@aws-sdk/s3-request-presigner": "^3.1078.0",
    "@prisma/client": "^6.9.0",
    "argon2": "^0.41.1",
    "axios": "^1.18.1",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "exceljs": "^4.4.0",
    "express": "^4.21.2",
    "express-rate-limit": "^7.5.0",
    "helmet": "^8.1.0",
    "hpp": "^0.2.3",
    "jsonwebtoken": "^9.0.2",
    "mime-types": "^3.0.2",
    "multer": "^1.4.5-lts.1",
    "nodemailer": "^6.10.1",
    "pino": "^9.6.0",
    "pino-http": "^10.4.0",
    "unzipper": "^0.12.5",
    "uuid": "^11.1.0",
    "zod": "^3.24.4"
  },
  "devDependencies": {
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^10.1.0",
    "eslint-plugin-node": "^11.1.0",
    "jest": "^29.7.0",
    "nodemon": "^3.1.9",
    "pino-pretty": "^13.0.0",
    "prisma": "^6.9.0",
    "supertest": "^7.1.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
