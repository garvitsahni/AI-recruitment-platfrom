# ========================
# Application
# ========================
NODE_ENV=development
PORT=3001
FRONTEND_URL=http://localhost:3000

# ========================
# Database
# ========================
DATABASE_URL=postgresql://recruitment:recruitment_dev@localhost:5432/recruitment_platform?schema=public

# ========================
# JWT Authentication
# ========================
JWT_SECRET=your-jwt-secret-change-in-production
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=your-refresh-secret-change-in-production
JWT_REFRESH_EXPIRES_IN=7d

# ========================
# AWS
# ========================
AWS_REGION=ap-south-1
AWS_ACCESS_KEY_ID=your-access-key
AWS_SECRET_ACCESS_KEY=your-secret-key
S3_BUCKET_NAME=recruitment-platform-documents
S3_SIGNED_URL_EXPIRY=3600

# ========================
# AI Service
# ========================
AI_SERVICE_URL=http://localhost:8000
AI_SERVICE_TIMEOUT=30000
AI_SERVICE_RETRIES=3

# ========================
# LLM Provider (used by ai-service)
# ========================
LLM_PROVIDER=openai
OPENAI_API_KEY=your-openai-api-key
ANTHROPIC_API_KEY=your-anthropic-api-key
GOOGLE_API_KEY=your-google-api-key

# ========================
# Email (Nodemailer / SendGrid)
# ========================
EMAIL_PROVIDER=nodemailer
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SENDGRID_API_KEY=your-sendgrid-key

# ========================
# Rate Limiting
# ========================
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# ========================
# Logging
# ========================
LOG_LEVEL=debug

# ========================
# Frontend (Next.js)
# ========================
NEXT_PUBLIC_API_URL=http://localhost:3001/api

# ========================
# Citation Verification
# ========================
FUZZY_MATCH_THRESHOLD=0.85
